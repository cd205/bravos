# /etc/bravos/env -- template for production deployment on bravos-vm1
# Copy to /etc/bravos/env, fill in BRAVOS_DB_PASSWORD and ALERT_EMAIL, then:
#   sudo chown root:root /etc/bravos/env
#   sudo chmod 600 /etc/bravos/env
# (D-08: root-readable only; systemd reads the file on behalf of the service user.)
#
# Bravos site credentials, IBKR account credentials, SMTP password, and
# Gmail App Password are fetched from GCP Secret Manager via get_secret()
# at runtime -- they do NOT belong in this file.
# Gmail App Password setup (one-time, required for bravos-gmail.service):
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to myaccount.google.com/apppasswords
#   3. Create an App Password (label: "bravos-vm1") and copy the 16-char code.
#   4. Store it:  echo -n "xxxx-xxxx-xxxx-xxxx" | \
#                   gcloud secrets create bravos-gmail-app-password --data-file=-
#   5. Apply the DB migration: psql -h 127.0.0.1 -U bravos bravos_trading \
#                                -f /home/chris_s_dodd/bravos/infra/migrate_gmail.sql

# ---------------------------------------------------------------------------
# Trading mode (D-04, D-05): "paper" -> IBKR port 4002; "live" -> IBKR port 4001
# Live cutover procedure (Plan 03):
#   1. Change to: TRADING_MODE=live
#   2. sudo systemctl restart bravos-trading.service
#   3. Confirm in journalctl: "IBKR connected -- mode=live ... port=4001"
# ---------------------------------------------------------------------------
TRADING_MODE=paper

# ---------------------------------------------------------------------------
# Database (BRAVOS_DB_PASSWORD is REQUIRED -- read directly in run_ingestion.py
# line 67 because psycopg2 connects synchronously and cannot call GCP Secret
# Manager at connect time). All other DB_* vars have working defaults in
# bravos/config/settings.py and only need to be set if non-default.
# ---------------------------------------------------------------------------
BRAVOS_DB_PASSWORD=
# BRAVOS_DB_HOST=localhost
# BRAVOS_DB_PORT=5432
# BRAVOS_DB_NAME=bravos_trading
# BRAVOS_DB_USER=bravos

# ---------------------------------------------------------------------------
# IBKR connection (defaults in settings.py; usually no override needed)
# ---------------------------------------------------------------------------
# IBKR_HOST=127.0.0.1
# IBKR_CLIENT_ID=1

# ---------------------------------------------------------------------------
# Notifications (Phase 7 -- NOTF-01, NOTF-02)
# ---------------------------------------------------------------------------
ALERT_EMAIL=

# ---------------------------------------------------------------------------
# Risk controls (Phase 4 defaults from settings.py; override here per deployment)
# ---------------------------------------------------------------------------
MAX_OPEN_POSITIONS=20
MAX_ALLOCATION_PCT=0.25
DAILY_LOSS_THRESHOLD=-5000.0
WEIGHT_PCT_PER_UNIT=0.05
